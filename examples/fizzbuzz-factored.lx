let fizzbuzz_value =
    \ n & n % 15 == 0 -> "FizzBuzz"
    | n & n % 3 == 0  -> "Fizz"
    | n & n % 5 == 0  -> "Buzz"
    | n               -> n;

let map_range =
    \ _, i, max & i > max -> []
    | f, i, max -> f(i) :: map_range(f, i + 1, max);

let fizzbuzz_factored =
    \ max -> map_range(fizzbuzz_value, 1, max);

(
    fizzbuzz_merged(1, 30),
    fizzbuzz_factored(30)
)
