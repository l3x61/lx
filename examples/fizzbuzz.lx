let fizzbuzz =
    \ n & n % 15 == 0 -> print("FizzBuzz")
    | n & n % 3  == 0 -> print("Fizz")
    | n & n % 5  == 0 -> print("Buzz")
    | n               -> print(n);

let loop =
    \ i, max & i > max -> print("Done.")
    | i, max           -> (
        let _ = fizzbuzz(i);
        loop(i + 1, max)
    );

loop(1, 15)
